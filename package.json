{
  "name": "cryptoi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check:security-config": "node scripts/check-security-config.mjs",
    "check:ci": "npm run lint && npm run typecheck && npm run test && npm run check:security-config",
    "db:generate": "node scripts/setup-env.js && prisma generate --schema=./backend/prisma/schema.prisma",
    "db:push": "node scripts/setup-env.js && prisma db push --schema=./backend/prisma/schema.prisma",
    "db:migrate": "node scripts/setup-env.js && prisma migrate dev --schema=./backend/prisma/schema.prisma",
    "db:studio": "node scripts/setup-env.js && prisma studio --schema=./backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "@tanstack/react-query": "^5.90.21",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.35.0",
    "jsonwebtoken": "^9.0.2",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-intl": "^3.26.5",
    "prisma": "^5.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
